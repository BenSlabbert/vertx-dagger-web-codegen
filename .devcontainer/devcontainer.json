{
  "name": "devcontainer",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  "runArgs": [
    "--privileged",
    "--device=/dev/fuse"
  ],
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "25.0.3-graal"
    },
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current"
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get install -y podman uidmap slirp4netns fuse-overlayfs && chmod +x gradlew && ./gradlew build -x test --console=plain && podman --version"
}
